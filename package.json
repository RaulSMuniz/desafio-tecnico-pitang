{
  "name": "desafio-tecnico-pitang",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo para o desafio técnico da Pitang",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:backend": "npm run dev --workspace=pitang-backend",
    "dev:frontend": "npm run dev --workspace=pitang-frontend",
    "dev": "npx concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "test": "npm test --workspaces",
    "build": "npm run build --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
